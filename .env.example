# Copy to .env and edit. The MCP server loads .env automatically if present.

# SSH host alias for the cluster (must work as `ssh $HOST` without password,
# e.g. via ~/.ssh/config + keys).
VIBEMATSCI_HOST=cluster

# Remote directory under which run dirs are created.
VIBEMATSCI_WORK_ROOT=~/vibematsci_runs

# Name of the remote micromamba / conda env that has mace-torch + ase + torch (CUDA).
VIBEMATSCI_MACE_ENV=mace

# Path to micromamba on the cluster (or "micromamba"/"conda" if on $PATH there).
VIBEMATSCI_MICROMAMBA=micromamba
